# =============================================================
# CareRota — Environment Variables
# Copy to .env.local and fill in values
# =============================================================

# ---------- Kinde Auth ----------
# Get these from https://app.kinde.com → Settings → Applications → Backend App
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://YOUR_SUBDOMAIN.kinde.com
KINDE_SITE_URL=http://localhost:3000
KINDE_POST_CALLBACK_URL=http://localhost:3000/api/auth/kinde/callback
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000
KINDE_AUTH_API_PATH=/api/auth/kinde

# Kinde Webhook — get from Kinde Dashboard → Webhooks → your webhook → Signing Secret
KINDE_WEBHOOK_SECRET=

# ---------- Database ----------
# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ---------- Email (Resend) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@carerota.co.uk

# ---------- SMS (Twilio) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
