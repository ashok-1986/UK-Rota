# =============================================================
# CareRota — Environment Variables
# Copy to .env.local and fill in values
# =============================================================

# Clerk env vars removed — auth migrated to Kinde (Phase 3)

# ---------- Kinde Auth ----------
# Get these from https://app.kinde.com → Settings → Applications → Backend App
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://alchemetryx.kinde.com
KINDE_SITE_URL=https://uk-rota.vercel.app
KINDE_POST_CALLBACK_URL=https://uk-rota.vercel.app/api/auth/kinde/callback
KINDE_POST_LOGIN_REDIRECT_URL=https://uk-rota.vercel.app/dashboard
KINDE_POST_LOGOUT_REDIRECT_URL=https://uk-rota.vercel.app
KINDE_AUTH_API_PATH=/api/auth/kinde
KINDE_WEBHOOK_SECRET= # not used — Kinde uses JWKS verification

# Kinde webhooks use JWT + JWKS verification — no shared secret needed.
# JWKS endpoint: https://alchemetryx.kinde.com/.well-known/jwks

# ---------- Database ----------
# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ---------- Email (Resend) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@carerota.co.uk

# ---------- SMS (Twilio) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=https://uk-rota.vercel.app

# ---------- Cron ----------
CRON_SECRET=
